{
  "name": "t20",
  "version": "0.0.1",
  "type": "module",
  "license": "GPL-3.0-only",
  "description": "A scaffolding CLI tool for Twenty CRM",
  "main": "dist/main.cjs",
  "bin": {
    "t20": "dist/main.cjs"
  },
  "author": "Ebrahim Khalil <ebrahim.khalil.nayeem@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/saeidex/t20"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsup && bun copy-package-json",
    "build:ts": "tsup",
    "clean": "rimraf dist/*",
    "check": "tsgo -p tsconfig.src.json --noEmit",
    "dev": "vitest",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint --fix -c .oxlintrc.json .",
    "typecheck": "tsgo -p tsconfig.src.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "copy-package-json": "tsx scripts/copy-package-json.ts",
    "changeset-version": "changeset version && node scripts/version.mjs",
    "changeset-publish": "pnpm build && changeset publish"
  },
  "prettier": {
    "printWidth": 65,
    "useTabs": false,
    "bracketSpacing": true,
    "tabWidth": 2
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@clack/prompts": "^1.6.0",
    "@types/copy-paste": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/pluralize": "^0.0.33",
    "@typescript/native-preview": "7.0.0-dev.20260310.1",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^4.1.9",
    "commander": "^15.0.0",
    "copy-paste": "^2.2.0",
    "eslint-plugin-codegen": "0.28.0",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "oxlint": "^1.71.0",
    "picocolors": "^1.1.1",
    "pluralize": "^8.0.0",
    "ts-dedent": "^2.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "twenty-sdk": "2.13.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1",
    "valibot": "^1.4.2",
    "vitest": "^4.1.9"
  }
}
